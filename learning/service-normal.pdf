@Injectable() // Permite que NestJS pueda inyectar este service en otras clases (ej: controller)
export class TaxTypesService {
  constructor(
    @InjectRepository(TaxTypeEntity) // Le pide a Nest el repository de esta entity
    private taxTypeRepository: Repository<TaxTypeEntity>, // Propiedad donde se guarda el repo para usarlo en la clase
  ) {}

  async findAll(): Promise<TaxTypeResponseDto[]> { // Método que devuelve todos los registros como DTOs
    const entities = await this.taxTypeRepository.find({
      where: { isDeleted: false }, // Filtra solo los no eliminados (soft delete)
      order: { createdAt: 'DESC' }, // Ordena del más nuevo al más viejo
    });

    return entities.map(TaxTypeResponseDto.fromEntity); // Convierte cada entity a DTO
  }

  async findById(id: number): Promise<TaxTypeResponseDto> { // Busca un registro por id
    const entity = await this.findOne(id); // Usa método interno que ya valida existencia
    return TaxTypeResponseDto.fromEntity(entity); // Convierte a DTO antes de devolver
  }

  async create(dto: CreateTaxTypeDto): Promise<TaxTypeResponseDto> { // Crea un nuevo registro
    await this.ensureCodeIsUnique(dto.code); // Valida que el código no esté repetido

    const newEntity = this.taxTypeRepository.create(dto); // Convierte el DTO a entity (sin guardar)
    const saved = await this.taxTypeRepository.save(newEntity); // Guarda en la base de datos

    return TaxTypeResponseDto.fromEntity(saved); // Devuelve el resultado como DTO
  }

  async update(
    id: number,
    changes: UpdateTaxTypeDto,
  ): Promise<TaxTypeResponseDto> { // Actualiza un registro existente
    const entity = await this.findOne(id); // Busca la entity o lanza error si no existe

    if (changes.code && changes.code !== entity.code) { // Solo valida si el código cambió
      await this.ensureCodeIsUnique(changes.code); // Evita duplicados
    }

    const merged = this.taxTypeRepository.merge(entity, changes); // Mezcla datos actuales con los nuevos
    const saved = await this.taxTypeRepository.save(merged); // Guarda los cambios

    return TaxTypeResponseDto.fromEntity(saved); // Devuelve DTO actualizado
  }

  async delete(id: number): Promise<void> { // Elimina (soft delete) un registro
    const entity = await this.findOne(id); // Busca la entity

    if (entity.isDeleted) return; // Si ya está eliminado, no hace nada (idempotente)

    entity.isDeleted = true; // Marca como eliminado
    await this.taxTypeRepository.save(entity); // Guarda el cambio en la DB
  }

  private async findOne(id: number): Promise<TaxTypeEntity> { // Método interno reutilizable
    const entity = await this.taxTypeRepository.findOne({
      where: { id, isDeleted: false }, // Busca por id y que no esté eliminado
    });

    if (!entity) {
      throw new NotFoundException(`Tax type with id ${id} not found`); // Error 404 si no existe
    }

    return entity; // Devuelve la entity encontrada
  }

  private async ensureCodeIsUnique(code: string): Promise<void> { // Valida que no haya códigos duplicados
    const existing = await this.taxTypeRepository.findOne({
      where: { code }, // Busca si ya existe ese código
    });

    if (existing) {
      throw new BadRequestException(
        `Tax type with code "${code}" already exists`, // Error 400 si está repetido
      );
    }
  }
}