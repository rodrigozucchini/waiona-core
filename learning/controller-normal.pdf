@Controller('tax-types') // Define la ruta base: /tax-types
export class TaxTypesController {
  constructor(private taxTypesService: TaxTypesService) {} // Inyección del service

  @Get() // GET /tax-types
  getTaxTypes(): Promise<TaxTypeResponseDto[]> {
    return this.taxTypesService.findAll(); // Llama al service para traer todos
  }

  @Get(':id') // GET /tax-types/:id
  findTaxType(
    @Param('id', ParseIntPipe) id: number, // Toma el id de la URL y lo convierte a number
  ): Promise<TaxTypeResponseDto> {
    return this.taxTypesService.findById(id); // Busca uno por id
  }

  @Post() // POST /tax-types
  createTaxType(
    @Body() body: CreateTaxTypeDto, // Toma el body de la request (datos para crear)
  ): Promise<TaxTypeResponseDto> {
    return this.taxTypesService.create(body); // Llama al service para crear
  }

  @Patch(':id') // PATCH /tax-types/:id
  updateTaxType(
    @Param('id', ParseIntPipe) id: number, // Obtiene el id de la URL
    @Body() changes: UpdateTaxTypeDto, // Obtiene los cambios del body
  ): Promise<TaxTypeResponseDto> {
    return this.taxTypesService.update(id, changes); // Actualiza el registro
  }

  @Delete(':id') // DELETE /tax-types/:id
  @HttpCode(HttpStatus.NO_CONTENT) // Responde con 204 (sin contenido)
  deleteTaxType(
    @Param('id', ParseIntPipe) id: number, // Obtiene el id de la URL
  ): Promise<void> {
    return this.taxTypesService.delete(id); // Ejecuta el soft delete
  }
}